# docker/ib-gateway/.env — loaded by docker compose for the IB Gateway
# container (`ghcr.io/gnzsnz/ib-gateway`). Required when running
# `npm run ib:start` on laptop.
#
#   cp docker/ib-gateway/.env.example docker/ib-gateway/.env
#
# On Hetzner the equivalent values live in /home/radon/radon-cloud/.env
# (single file for both Python and the systemd unit).

TWS_USERID=your_ib_username
TWS_PASSWORD=xxxxxxxxxxxxxxxxxx
TRADING_MODE=live
READ_ONLY_API=no
TWS_ACCEPT_INCOMING=accept
# `manual` blocks new login when IB sees an existing session;
# `secondary` auto-takes over.
EXISTING_SESSION_DETECTED_ACTION=manual

IB_LIVE_PORT=4001
IB_PAPER_PORT=4002
# Optional alternative to TWS_PASSWORD — file path read inside container.
# IB_PASSWORD_FILE=./secrets/ib_password.txt

# VNC for 2FA debugging (requires docker-compose.override.yml to expose 5900).
VNC_SERVER_PASSWORD=xxxxxxxx
