# IB Gateway connection
# IB_GATEWAY_HOST=127.0.0.1    # Local Docker (default)
# IB_GATEWAY_HOST=ib-gateway    # Cloud (Tailscale MagicDNS)
# IB_GATEWAY_PORT=4001
# IB_GATEWAY_MODE=docker        # "docker" (default) | "cloud" (remote, no restart) | "launchd"

# CTA data
# MENTHORQ_USER=
# MENTHORQ_PASS=

# Newsfeed (themarketear.com) — headless Playwright login credentials.
# Required when running scripts/newsfeed/index.js. The scraper persists a
# session at data/newsfeed-storage.json and only re-authenticates ~every 6h.
# THEMARKETEAR_EMAIL=
# THEMARKETEAR_PASSWORD=
# RADON_NEWSFEED_HEADLESS=1   # set to 0 to launch a visible browser for debugging
