# Root .env — loaded by python-dotenv for FastAPI, scrapers, schedulers,
# IB Gateway, and the watchdog. Copy to .env and fill in values.
#
#   cp .env.example .env
#
# Mirrors the production layout on the Hetzner VPS at
# /home/radon/radon-cloud/.env. Marked vars are required for production;
# optional vars degrade gracefully when unset.
#
# IMPORTANT: values containing `$` MUST be single-quoted. Bash loaders
# (`set -a; . file; set +a`) shell-expand `$VAR` substrings and under
# `set -u` an unset reference aborts silently from systemd. Single-quote
# the value (`PASS='RX$abc!xyz'`) or use a non-shell loader (systemd
# EnvironmentFile=, python-dotenv). See feedback_env_file_shell_expansion.md.

# =============================================================================
# Mode / deployment (required)
# =============================================================================
# `local`  — laptop-resident schedulers (launchd)
# `hetzner` — Hetzner-resident schedulers (systemd)
RADON_MODE=local
# Hostname Caddy serves. `localhost` for dev, `app.radon.run` on Hetzner.
DOMAIN=localhost
# Internal API base used by Next.js → FastAPI server-to-server. Auth
# bypass for localhost/::1 is wired into FastAPI; production points at
# the Tailscale-side hostname.
RADON_API_URL=http://localhost:8321
NEXT_PUBLIC_RADON_API_URL=http://localhost:8321
# WS relay (`ib_realtime_server.js`) URL exposed to the browser.
NEXT_PUBLIC_IB_REALTIME_WS_URL=ws://localhost:8765
# Standard Node knobs (Next.js process).
NODE_ENV=development
PORT=3000

# =============================================================================
# IB Gateway connection (required)
# =============================================================================
# `docker` (default) | `cloud` (remote, no restart) | `launchd` (legacy)
IB_GATEWAY_MODE=docker
IB_GATEWAY_HOST=127.0.0.1
IB_GATEWAY_PORT=4001
# Hetzner-only: compose project dir for the radon-cloud-owned IB Gateway
# container (`radon-ib-gateway.service` launches docker compose from here,
# NOT the in-tree docker/ib-gateway/). Required on Hetzner; leave unset
# on laptop.
# IB_GATEWAY_COMPOSE_DIR=/home/radon/radon-cloud

# =============================================================================
# IB Gateway login (required when running the Docker container)
# =============================================================================
# Consumed by ghcr.io/gnzsnz/ib-gateway via docker/ib-gateway/.env on
# laptop. Trading mode + read-only flag are passed straight through to
# IB Gateway. `live` is the only mode wired up; `paper` is untested.
TWS_USERID=your_ib_username
TWS_PASSWORD=xxxxxxxxxxxxxxxxxx
TRADING_MODE=live
READ_ONLY_API=no
TWS_ACCEPT_INCOMING=accept
# VNC password for the IB Gateway container — needed only when 2FA push
# fails and you have to click the prompt by hand. Pair with a
# docker-compose.override.yml to expose port 5900.
VNC_SERVER_PASSWORD=xxxxxxxx
# `manual` | `secondary` — controls behaviour when IB detects an
# existing session. `manual` blocks the new login (operator must approve
# in the desktop client); `secondary` auto-takes over.
EXISTING_SESSION_DETECTED_ACTION=manual

# =============================================================================
# IB Flex Web Service (required for blotter, cash flows, journal rehydrate)
# =============================================================================
IB_FLEX_TOKEN=xxxxxxxxxxxxxxxxxxxx
# Trade blotter Flex query ID (canonical).
IB_FLEX_QUERY_ID=1422766
# CashTransaction-only Flex query ID. DO NOT repurpose for trade pulls.
IB_FLEX_NAV_QUERY_ID=1497709

# =============================================================================
# Turso (required — source of truth for journal, service_health, etc)
# =============================================================================
# Embedded-replica syncs to data/replica.db. Only one long-running
# process per host can hold replica.db open; second writer crashes with
# WalConflict — set RADON_DB_NO_REPLICA=1 in scrapers/schedulers.
TURSO_DB_URL=libsql://radon-<workspace>.turso.io
TURSO_AUTH_TOKEN=eyJ...

# =============================================================================
# Clerk authentication (required in production; bypassed on localhost)
# =============================================================================
# JWT verification side (FastAPI):
CLERK_ISSUER=https://example.clerk.accounts.dev
CLERK_JWKS_URL=https://example.clerk.accounts.dev/.well-known/jwks.json
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxx
# Comma-separated list of Clerk user IDs allowed into the terminal.
ALLOWED_USER_IDS=user_xxxxxxxxxxxxxxxxxxxxx
# Next.js side:
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# =============================================================================
# Unusual Whales (required for scanner/discover/options-flow/dark-pool)
# =============================================================================
UW_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# =============================================================================
# AI / LLM providers
# =============================================================================
# Required for vision tagger, seasonality fallback, assistant chat,
# share-card OG renders.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxx
# Used by the newsfeed text tagger (gpt-oss-120b → qwen-3 fallback). The
# router falls back to Anthropic when this is unset; tagging is skipped
# entirely if both providers are missing.
CEREBRAS_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxx

# =============================================================================
# Newsfeed scraper (themarketear.com) — required if running scripts/newsfeed/
# =============================================================================
# Headless Playwright login. Storage cached at data/newsfeed-storage.json
# (~30d), full re-auth every ~6h.
THEMARKETEAR_EMAIL=your_account@example.com
THEMARKETEAR_PASSWORD=xxxxxxxxxxxxxxxxxx
# RADON_NEWSFEED_HEADLESS=1   # set 0 to launch a visible browser for debugging

# =============================================================================
# MenthorQ CTA (required for /menthorq/* surfaces)
# =============================================================================
MENTHORQ_USER=your_account@example.com
MENTHORQ_PASS=xxxxxxxxxxxxxxxxxx
# MarketDataWorks API key — feeds CTA enrichment.
MDW_API_KEY=xxxxxxxxxxxxxxxxxx

# =============================================================================
# Media host (Hetzner only)
# =============================================================================
# Where the laptop rsyncs newsfeed images to. On the VPS itself this is
# a local fs path (rsync skips SSH self-loop).
# Laptop default: radon@5.78.148.38:/home/radon/radon-cloud/media/
# Hetzner default: /home/radon/radon-cloud/media/
# RADON_MEDIA_REMOTE=radon@5.78.148.38:/home/radon/radon-cloud/media/

# =============================================================================
# Watchdog alert routing (optional — absent vars degrade gracefully)
# =============================================================================
# Pushover is the only external channel. P1 alerts cut through iOS DnD;
# P2/P3 land in the service_health table only. When unset, the watchdog
# prints a one-line startup warning and writes alerts to service_health.
# PUSHOVER_USER=u123abc...
# PUSHOVER_TOKEN=axxxxxxxxxxxxxxxxxxxxxxxxxxxx
