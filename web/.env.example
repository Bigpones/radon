# web/.env — loaded by Next.js (web/ workspace). Copy to web/.env and
# fill in values before `npm run dev` / build.
#
#   cp web/.env.example web/.env
#
# The root .env is loaded by python-dotenv for FastAPI / scripts; this
# file is loaded by Next.js. Some vars are repeated across both because
# Next.js can't read the root file from inside web/.

# =============================================================================
# AI / LLM providers (required)
# =============================================================================
# Anthropic / Claude API key — assistant chat, share-card OG renders,
# vision tagger, seasonality vision fallback. Either of the
# CLAUDE_CODE_API_KEY / CLAUDE_API_KEY aliases is accepted by
# resolveApiKey().
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxx
CLAUDE_CODE_API_KEY=
CLAUDE_API_KEY=
# Optional model / endpoint overrides.
# ANTHROPIC_MODEL=claude-sonnet-4-5-20250929
# ANTHROPIC_API_URL=https://api.anthropic.com/v1/messages

# Cerebras inference — newsfeed text tagger. Falls back to Anthropic when unset.
CEREBRAS_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxx

# =============================================================================
# Unusual Whales (required for scanner / discover / flow / dark-pool routes)
# =============================================================================
UW_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# =============================================================================
# Exa search (optional — get key at https://dashboard.exa.ai/api-keys)
# =============================================================================
EXA_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxx

# =============================================================================
# Clerk authentication (required in production; bypassed in dev / Playwright)
# =============================================================================
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# =============================================================================
# Backend wiring (required)
# =============================================================================
# WS relay (`ib_realtime_server.js`) URL exposed to the browser.
IB_REALTIME_WS_URL=ws://localhost:8765
NEXT_PUBLIC_IB_REALTIME_WS_URL=ws://localhost:8765
# Internal FastAPI base. Localhost values get the auth bypass.
RADON_API_URL=http://localhost:8321
NEXT_PUBLIC_RADON_API_URL=http://localhost:8321
